HOST=0.0.0.0
PORT=3000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/meatland?schema=public
REDIS_URL=redis://localhost:6379

JWT_SECRET=replace-with-a-long-random-secret
JWT_ISSUER=meatland-api
JWT_SHIFT_TOKEN_TTL=8h
CUSTOMER_SESSION_TOKEN_TTL=2h
CUSTOMER_SESSION_ACTIVATION_RATE_LIMIT_BURST=5
CUSTOMER_SESSION_ACTIVATION_RATE_LIMIT_WINDOW_SECONDS=60
API_BODY_LIMIT_BYTES=1048576
READY_PROBE_TIMEOUT_MS=1500
READY_DEGRADED_LATENCY_MS=400
READY_REQUIRED_MIN_STATUS=degraded

MAGIC_LINK_BASE_URL=http://localhost:8080/m
MAGIC_LINK_TTL_SECONDS=86400
CATALOG_CACHE_TTL_SECONDS=300
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:8081,http://127.0.0.1:8081,exp://10.0.0.25:8081,http://127.0.0.1:3000

# Hashavshevet environment switcher
# Set HASH_ENV to testing or production, then set matching URL + key.
# HASH_API_URL / HASH_API_KEY (if set) override HASH_*_API_URL and HASH_*_API_KEY.
HASH_ENV=testing
HASH_TEST_API_URL=
HASH_TEST_API_KEY=
HASH_PROD_API_URL=
HASH_PROD_API_KEY=
HASH_API_URL=
HASH_API_KEY=
HASH_REQUEST_TIMEOUT_MS=8000
HASH_HEALTH_PATH=/health
HASH_ASSIGNED_CUSTOMERS_PATH=/agents/{agentId}/customers
HASH_CATALOG_PATH=/catalog/items
HASH_RECENT_ITEMS_PATH=/customers/{customerId}/recent-items
HASH_PRICING_PATH=/customers/{customerId}/pricing

# Hashavshevet H-Connect (plugin-based) integration.
# Enable this mode when using ws.wizground.com plugin envelopes/signatures.
HASH_HCONNECT_ENABLED=false
HASH_HCONNECT_ENDPOINT_URL=https://ws.wizground.com/api
HASH_HCONNECT_STATION=
HASH_HCONNECT_COMPANY=
HASH_HCONNECT_NET_PASSPORT_ID=
HASH_HCONNECT_SIGNATURE_TOKEN=

# H-Connect report mappings (encrypted report definitions from Hashavshevet setup).
HASH_HCONNECT_REPORT_ASSIGNED_CUSTOMERS=
HASH_HCONNECT_REPORT_CATALOG=
HASH_HCONNECT_REPORT_RECENT_ITEMS=
HASH_HCONNECT_REPORT_PRICING=

# Optional JSON templates for report params_data (supports ${agentId} / ${customerId} placeholders).
HASH_HCONNECT_REPORT_ASSIGNED_CUSTOMERS_PARAMS_JSON=
HASH_HCONNECT_REPORT_CATALOG_PARAMS_JSON=
HASH_HCONNECT_REPORT_RECENT_ITEMS_PARAMS_JSON=
HASH_HCONNECT_REPORT_PRICING_PARAMS_JSON=

# Order handoff plugin configuration (currently imovein is implemented).
HASH_HCONNECT_HANDOFF_PLUGIN=imovein
HASH_HCONNECT_HANDOFF_DOCUMENT_ID=30
HASH_HCONNECT_HANDOFF_ACCOUNT_KEY=
