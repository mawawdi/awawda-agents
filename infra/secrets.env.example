# =============================================================================
# CLASSIFIED SECRETS — copy this file to infra/secrets.env and fill in values.
# Never commit infra/secrets.env. Never log or print these values.
# =============================================================================

# Application
JWT_SECRET=

# Hashavshevet REST API keys (if applicable — leave empty if using H-Connect only)
HASH_PROD_API_KEY=
HASH_TEST_API_KEY=
HASH_API_KEY=

# H-Connect connection credentials
# HASH_HCONNECT_STATION   — station UUID from Hashavshevet setup
# HASH_HCONNECT_COMPANY   — company name in Hashavshevet
# HASH_HCONNECT_NET_PASSPORT_ID — supplier name under הגדרות → H-Connect → ספקים
# HASH_HCONNECT_SIGNATURE_TOKEN — token from Hashavshevet H-Connect settings
HASH_HCONNECT_STATION=
HASH_HCONNECT_COMPANY=
HASH_HCONNECT_NET_PASSPORT_ID=
HASH_HCONNECT_SIGNATURE_TOKEN=

# H-Connect encrypted report definitions (extract_reportData from Hashavshevet)
HASH_HCONNECT_REPORT_ASSIGNED_CUSTOMERS=
HASH_HCONNECT_REPORT_CATALOG=
HASH_HCONNECT_REPORT_RECENT_ITEMS=
HASH_HCONNECT_REPORT_PRICING=
HASH_HCONNECT_REPORT_OBLIGO=
HASH_HCONNECT_REPORT_OPEN_DELIVERY_NOTES_LIST=
HASH_HCONNECT_REPORT_VENDORS=
HASH_HCONNECT_REPORT_SPECIAL_PRICES_INDEX=
HASH_HCONNECT_REPORT_AGENTS=
HASH_HCONNECT_REPORT_OPEN_DELIVERY_NOTES_BY_CUSTOMER=
HASH_HCONNECT_REPORT_CUSTOMER_SPECIAL_PRICING=
HASH_HCONNECT_REPORT_CUSTOMER_BALANCE=
HASH_HCONNECT_REPORT_CUSTOMER_LEDGER=
HASH_HCONNECT_REPORT_STOCK_STATUS=

# H-Connect order handoff account key
HASH_HCONNECT_HANDOFF_ACCOUNT_KEY=
